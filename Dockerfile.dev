FROM mcr.microsoft.com/devcontainers/javascript-node:22-bookworm

USER root

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    build-essential \
    git \
    curl \
    tmux \
    ca-certificates \
    qpdf \
    poppler-utils \
    ghostscript \
    tesseract-ocr \
    tesseract-ocr-fra \
    tesseract-ocr-eng \
    ocrmypdf \
    libreoffice \
    bubblewrap \
    && rm -rf /var/lib/apt/lists/*

# Installation officielle Codex CLI macOS/Linux.
# Ne jamais faire le login dans l'image Docker.

RUN mkdir -p /home/node/.codex /home/node/.local/bin /home/node/.cache/uv \
    && chown -R node:node /home/node/.codex /home/node/.local /home/node/.cache

RUN chsh -s /usr/bin/zsh node

ENV CODEX_HOME=/home/node/.codex
ENV UV_CACHE_DIR=/home/node/.cache/uv
ENV PATH="/home/node/.local/bin:${PATH}"

USER node


RUN curl -LsSf https://astral.sh/uv/install.sh | sh

RUN test -x /usr/bin/zsh \
    && test -d /home/node/.oh-my-zsh \
    && test -f /home/node/.zshrc \
    && test "$(stat -c '%U:%G' /home/node/.zshrc)" = "node:node" \
    && zsh -ic 'case ":$PATH:" in *:/home/node/.local/bin:*) exit 0 ;; *) exit 1 ;; esac' \
    && uv --version

ENV PATH="/home/node/.local/bin:${PATH}"

WORKDIR /workspace

ENV PYTHONUNBUFFERED=1
ENV CODEX_HOME=/home/node/.codex
